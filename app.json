{
  "expo": {
    "name": "ShopNest",
    "slug": "shopnest",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "shopnest",
    "platforms": ["ios", "android", "web"],
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "jsEngine": "hermes"
  }
}

